{
  "version": "1.0",
  "batch_id": "BATCH_GENERAL_DEDUCT_MERCHANT_EXPORT",
  "batch_name": "소득공제가맹점테이블 파일 생성",
  "batch_type": "db_to_file",
  "description": "소득공제가맹점 가맹점번호로 파일 생성하는 배치 만들어줘",
  "schedule_type": "daily",
  "parameters": [
    {
      "name": "base_date",
      "required": true,
      "description": "기준일자(YYYYMMDD)"
    }
  ],
  "source": {
    "table": "TB_GENERAL_DEDUCT_MERCHANT",
    "columns": [
      "MERCHANT_ID",
      "MERCHANT_NM",
      "BIZ_NO",
      "MCC_CD",
      "APPLY_START_DT",
      "APPLY_END_DT",
      "USE_YN",
      "REG_DTM",
      "UPD_DTM"
    ],
    "base_date_column": "APPLY_START_DT"
  },
  "target": {
    "output_format": "csv",
    "output_file_prefix": "general_deduct_merchant",
    "output_file_pattern": "general_deduct_merchant_{base_date}.csv",
    "output_dir": "./output",
    "encoding": "utf-8-sig"
  },
  "sql": "SELECT\n    MERCHANT_ID,\n    MERCHANT_NM,\n    BIZ_NO,\n    MCC_CD,\n    APPLY_START_DT,\n    APPLY_END_DT,\n    USE_YN,\n    REG_DTM,\n    UPD_DTM\nFROM TB_GENERAL_DEDUCT_MERCHANT\nWHERE :base_date BETWEEN APPLY_START_DT AND IFNULL(APPLY_END_DT, '99991231')\n  AND USE_YN = 'Y'",
  "validation_rules": {
    "min_rows": 0,
    "not_null_columns": [
      "MERCHANT_ID",
      "APPLY_START_DT"
    ]
  },
  "meta_source": {
    "type": "erwin_meta",
    "path": "C:\\Users\\KBCARD\\kb_project\\batch_dev\\metadata\\erwin_meta.json",
    "tables": [
      "TB_GENERAL_DEDUCT_MERCHANT"
    ]
  },
  "rule_source": {
    "rule_id": "active_period_export",
    "path": "C:\\Users\\KBCARD\\kb_project\\batch_dev\\business_rules\\active_period_export.json",
    "sql_template": "active_period_export.sql.j2"
  }
}