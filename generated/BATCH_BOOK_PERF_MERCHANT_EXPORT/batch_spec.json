{
  "version": "1.0",
  "batch_id": "BATCH_BOOK_PERF_MERCHANT_EXPORT",
  "batch_name": "도서공연가맹점테이블 파일 생성",
  "batch_type": "db_to_file",
  "description": "도서공연 가맹점 파일 생성 배치 만들어줘",
  "schedule_type": "manual",
  "parameters": [
    {
