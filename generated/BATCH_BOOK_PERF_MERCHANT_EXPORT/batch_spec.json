  "source": {
    "table_role": "classification_master",
    "column_roles": [],
    "base_date_column_role": "transaction_date",
    "dynamic_inference": true
  },
  "target": {
    "output_format": "csv",
    "output_file_prefix": "book_perf_merchant",
    "output_file_pattern": "book_perf_merchant_{base_date}.csv",
    "output_dir": "./output",
    "encoding": "utf-8-sig"
  },
  "sql": "SELECT\nMERCHANT_ID,\n    MERCHANT_NM,\n    BIZ_NO,\n    MCC_CD,\n    APPLY_START_DT,\n    APPLY_END_DT,\n    USE_YN,\n    REG_DTM,\n    UPD_DTM\nFROM TB_BOOK_PERF_MERCHANT\nWHERE :base_date >= APPLY_START_DT\n  AND (APPLY_END_DT IS NULL OR :base_date <= APPLY_END_DT)\n  AND USE_YN = 'Y'",
  "validation_rules": {
    "min_rows": 0,
    "not_null_columns": [
      "MERCHANT_ID",
      "APPLY_START_DT"
    ]
  },
