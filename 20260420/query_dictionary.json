{
  "ambiguous_terms": [
    "그거",
    "저거",
    "이거",
    "그 업무",
    "저 업무",
    "흐름도",
    "리니지",
    "테이블",
    "배치",
    "상세",
    "설명"
  ],
  "rewrite_policy": {
    "prefer_customer_domain_expansion": true,
    "prefer_recent_history": true,
    "keep_original_meaning": true
  },
  "rules": [
    {
      "name": "batch_flow_request",
      "patterns": ["배치\\s*흐름도", "배치", "플로우", "흐름도"],
      "canonical_suffix": "배치 흐름도 보여줘"
    },
    {
      "name": "table_lineage_request",
      "patterns": ["테이블\\s*리니지", "리니지", "테이블\\s*관계도"],
      "canonical_suffix": "테이블 리니지 보여줘"
    },
    {
      "name": "overview_request",
      "patterns": ["업무", "설명", "상세", "무엇", "뭐야"],
      "canonical_suffix": "업무 전체 설명 알려줘"
    },
    {
      "name": "incident_request",
      "patterns": ["장애", "오류", "실패", "장애현황"],
      "canonical_suffix": "장애 현황 알려줘"
    },
    {
      "name": "billing_statement_request",
      "patterns": ["청구", "이용내역", "이용내역서", "명세서"],
      "canonical_suffix": "청구 이용내역 조회 방법 알려줘"
    }
  ]
}
