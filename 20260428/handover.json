          "overview": {
            "title": "KKK은행 소득공제 업무 개요",
            "content": "KKK은행에서 발생한 카드 승인 및 매입 데이터, 가맹점 정보, 고객 정보 등을 수집한 뒤 소득공제 대상 여부를 판별하고, 정제된 결과를 내부 관리 시스템과 외부 제출 파일에 반영하는 일련의 처리 과정이다. 주요 처리 대상은 체크카드, 신용카드, 현금성 거래 중 소득공제 대상 거래이며, 거래 취소, 오류 데이터, 대상 제외 업종 등은 별도 기준에 따라 제외 또는 보정 처리한다."
          },
          "batch_process": {
            "title": "KKK은행 소득공제 배치 프로세스",
            "steps": [
              {
                "step": 1,
                "name": "데이터 적재",
                "execution": "parallel",
                "jobs": [
                  {
                    "job_id": "BATCH_01_CARD_APPROVAL_LOAD",
                    "description": "카드 승인 데이터 수집 및 적재"
                  },
                  {
                    "job_id": "BATCH_02_CARD_PURCHASE_LOAD",
                    "description": "카드 매입 데이터 수집 및 적재"
                  },
                  {
                    "job_id": "BATCH_03_CUSTOMER_INFO_LOAD",
                    "description": "고객 기본정보 적재"
                  },
                  {
                    "job_id": "BATCH_04_MERCHANT_INFO_LOAD",
                    "description": "가맹점 정보 및 업종코드 적재"
                  },
                  {
                    "job_id": "BATCH_05_CANCEL_DATA_LOAD",
                    "description": "취소 및 정정 거래 데이터 적재"
                  }
                ]
              },
              {
                "step": 2,
                "name": "소득공제 대상 처리",
                "execution": "sequential",
                "jobs": [
                  {
                    "job_id": "BATCH_06_DEDUCTION_TARGET_FILTER",
                    "description": "소득공제 대상 거래 판별 및 제외 업종/비대상 거래 제거"
                  },
                  {
                    "job_id": "BATCH_07_DEDUCTION_AGGREGATION",
                    "description": "고객별 소득공제 금액 집계 및 월별/연간 기준 데이터 생성"
                  }
                ]
              },
              {
                "step": 3,
                "name": "최종 결과 생성",
                "execution": "sequential",
                "jobs": [
                  {
                    "job_id": "BATCH_08_DEDUCTION_FILE_GENERATION",
                    "description": "대외 제출용 소득공제 파일 생성 및 내부 조회 시스템 반영 데이터 생성"
                  }
                ]
              }
