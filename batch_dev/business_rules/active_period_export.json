{
  "rule_id": "active_period_export",
  "description": "적용시작/종료일자와 사용여부를 가진 기준성 테이블을 기준일자로 조회해 파일로 생성한다.",
  "batch_type": "db_to_file",
  "priority": 100,
  "match": {
    "required_columns": ["APPLY_START_DT", "APPLY_END_DT", "USE_YN"],
    "request_any": ["파일", "CSV", "csv", "생성", "조회", "추출", "배치"]
  },
  "sql_template": "active_period_export.sql.j2",
  "defaults": {
    "output_format": "csv",
    "schedule_type": "daily",
    "base_date_column": "APPLY_START_DT"
  },
  "conditions": [
    {
      "id": "active_period",
      "template": ":base_date BETWEEN APPLY_START_DT AND {{ null_fn }}(APPLY_END_DT, '99991231')"
    },
    {
      "id": "use_yn",
      "template": "USE_YN = 'Y'"
    }
  ]
}
