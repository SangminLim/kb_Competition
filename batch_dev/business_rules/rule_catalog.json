{
  "version": "2.1",
  "description": "테이블명 고정 없이 ERWin 메타의 역할/관계로 배치 패턴을 선택한다.",
  "rules": [
    {
      "rule_id": "monthly_aggregation_dynamic",
      "rule_type": "monthly_aggregation",
      "batch_type": "aggregation_to_table",
      "priority": 100,
      "description": "거래 원장 역할 테이블을 기준으로 월별 집계 SQL을 생성한다. 조인 대상은 ERWin relations와 classification_master 역할로 추론한다.",
      "match": {
        "required_any": [
          "집계",
          "월별",
          "통합"
        ],
        "required_columns": [
          "CUSTOMER_ID",
          "MERCHANT_ID"
        ]
      },
      "target": {
        "table": "TB_DEDUCTION_MONTHLY_SUMMARY",
        "columns": [
          "CUSTOMER_ID",
          "BASE_YM",
          "MERCHANT_TYPE",
          "TOTAL_AMT",
          "TXN_COUNT",
          "REG_DTM"
        ]
      }
    },
    {
      "rule_id": "ledger_extract_with_classification",
      "rule_type": "ledger_extract",
      "batch_type": "db_to_file",
      "priority": 80,
      "description": "거래 원장과 분류 마스터를 ERWIN relation 기반으로 조인하여 대상 거래를 추출한다.",
      "match": {
        "required_any": [
          "대상 거래",
          "거래 추출",
          "가맹점 유형",
          "MERCHANT_TYPE",
          "참조 테이블"
        ],
        "required_table_roles": [
          "transaction_ledger",
          "classification_master"
        ]
      },
      "template_type": "ledger_extract_with_classification",
      "sql_template": "ledger_extract_with_classification.sql.j2"
    },
    {
      "rule_id": "generic_export_dynamic",
      "rule_type": "generic_export",
      "batch_type": "db_to_file",
      "priority": 10,
      "description": "단일 테이블 조건 조회 후 파일로 생성한다.",
      "match": {
        "required_any": [
          "파일",
          "CSV",
          "목록",
          "추출",
          "생성"
        ],
        "exclude_any": [
          "JOIN",
          "참조 테이블",
          "가맹점 유형",
          "MERCHANT_TYPE",
          "대상 거래",
          "거래 추출"
        ]
      },
      "sql_template": "generic_export.sql.j2",
      "conditions": [
        {
          "template": ":base_date >= APPLY_START_DT"
        },
        {
          "template": "(APPLY_END_DT IS NULL OR :base_date <= APPLY_END_DT)"
        },
        {
          "template": "USE_YN = 'Y'"
        }
      ]
    }
  ]
}